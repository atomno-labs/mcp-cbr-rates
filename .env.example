# mcp-cbr-rates does not require any secrets to function — CBR data is fully public.
# This file exists for forward-compatibility (e.g. if later v0.x adds opt-in telemetry).

# Optional: override default cache TTLs (seconds)
# MCP_CBR_CACHE_DAILY_TTL=3600
# MCP_CBR_CACHE_HISTORY_TTL=86400

# Optional: override default HTTP timeout (seconds)
# MCP_CBR_HTTP_TIMEOUT=15

# Optional: standard Python log level
# MCP_CBR_LOG_LEVEL=INFO
